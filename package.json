{
  "name": "stickdrift",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install": "npm install --prefix server && npm install --prefix client",
    "client:dev": "npm run dev --prefix client",
    "server:dev": "npm run dev --prefix server",
    "dev": "concurrently \"npm run server:dev\" \"wait-on tcp:4000 && npm run client:dev\"",
    "client:build": "npm run build --prefix client",
    "server:build": "npm run build --prefix server",
    "build": "concurrently \"npm run server:build\" \"npm run client:build\"",
    "start": "node server/dist/index.js",
    "seed": "npm run seed --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5"
  }
}
